# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Mapbox Configuration (Optional)
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# Azure AD (Entra ID) Configuration - Workforce Tenant
# Get these values from Azure Portal → App Registrations
VITE_AZURE_CLIENT_ID=your_azure_client_id_here
VITE_AZURE_TENANT_ID=your_azure_tenant_id_here
# OR use tenant domain instead of ID:
# VITE_AZURE_TENANT_DOMAIN=yourcompany.onmicrosoft.com

# Redirect URI (must match Azure App Registration)
VITE_AZURE_REDIRECT_URI=http://localhost:3004/

# Other Configuration
VITE_APP_ENV=development